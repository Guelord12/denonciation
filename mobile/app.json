{
  "expo": {
    "name": "Dénonciation",
    "slug": "denonciation",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#e63946"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.denonciation.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.png",
        "backgroundColor": "#e63946"
      },
      "package": "com.denonciation.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/logo.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Dénonciation to access your camera to take photos and videos for evidence."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Dénonciation to access your photos to upload evidence."
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Dénonciation to use your location to geotag reports."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "44c4f747-331a-49c1-9d82-aa189222a115"
      }
    },
    "owner": "galadji12"
  }
}
